BOT_TOKEN=your_telegram_bot_token_here
# Optional: Hardcoded IP for api.telegram.org to bypass DNS poisoning
TELEGRAM_API_IP=149.154.166.110

NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here

# AI Generation Engine (codex | gemini)
AI_ENGINE=codex
# Optional model for codex
CODEX_MODEL=gpt-4o
# Optional model for gemini (e.g., gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# WhatsApp Integration
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_API_VERSION=v22.0
